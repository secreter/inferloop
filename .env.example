# ---------------------------------------------------------------
# InferLoop 环境变量模板
# 把本文件复制为 .env.local（被 .gitignore 忽略），按需填值即可。
# 在 Cloudflare Pages 上：Settings → Environment variables → 添加。
# ---------------------------------------------------------------

# Cloudflare Web Analytics token
# 拿 token: dash.cloudflare.com → Web Analytics → Add a site → 拷贝 token
# 留空时本地 dev 完全不加载 beacon，无污染。
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
